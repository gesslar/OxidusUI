# Default: auto-detect text and normalize to LF on checkin
* text=auto eol=lf

# Source files - always LF
*.lua       text eol=lf
*.json      text eol=lf
*.json5     text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.js        text eol=lf

# Dotfiles / config
.gitattributes  text eol=lf
.gitignore      text eol=lf
.editorconfig   text eol=lf
mfile           text eol=lf

# Binary files - never normalize
*.ttf       binary
*.otf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.mpackage  binary
